generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  active    Boolean   @default(true)
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles  Vehicle[]

  @@index([active])
}

model Vehicle {
  id           Int        @id @default(autoincrement())
  plate        String     @unique
  digits       String
  company      String
  projectId    Int?
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contactName  String?
  contactPhone String?
  accessType   AccessType
  expiresAt    DateTime?
  isExpired    Boolean    @default(false)
  note         String?
  source       String     @default("manual")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  logs AccessLog[]

  @@index([digits])
  @@index([isExpired])
  @@index([accessType])
  @@index([projectId])
}

model EmergencyVehicle {
  id        Int      @id @default(autoincrement())
  plate     String   @unique
  digits    String
  note      String?
  addedBy   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([digits])
}

model AccessLog {
  id         Int       @id @default(autoincrement())
  plate      String
  vehicleId  Int?
  vehicle    Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  result     Result
  operatorId String?
  note       String?
  syncedAt   DateTime?
  timestamp  DateTime  @default(now())

  @@index([plate])
  @@index([timestamp])
  @@index([syncedAt])
}

enum AccessType {
  PERMANENT
  TEMPORARY
  SINGLE_USE
}

enum Result {
  ALLOWED
  DENIED
  UNKNOWN
}
